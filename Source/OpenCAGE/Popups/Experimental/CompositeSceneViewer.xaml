<UserControl x:Class="OpenCAGE.CompositeSceneViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:HelixToolkit="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <HelixToolkit:HelixViewport3D x:Name="viewport" ZoomExtentsWhenLoaded="False" ShowViewCube="True" ViewCubeVerticalPosition="Top" ShowCoordinateSystem="True" CoordinateSystemVerticalPosition="Top">
            <HelixToolkit:SunLight Altitude="160" Azimuth="120" Ambient="0.7" Brightness="1" />
            <HelixToolkit:GridLinesVisual3D x:Name="referenceGrid" Width="8" Length="8" MinorDistance="1" MajorDistance="1" Thickness="0.02" />
            <ModelVisual3D x:Name="sceneRoot" />
            <HelixToolkit:SortingVisual3D x:Name="transparentSorter" />
        </HelixToolkit:HelixViewport3D>

        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8" Padding="4" Background="#CC2B2B2B" BorderBrush="#666" BorderThickness="1" CornerRadius="3">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="moveModeButton" Content="Move (1)" GroupName="GizmoMode" Width="72" Height="26" Margin="2,0" IsChecked="True"
                                 ToolTip="Move selected entity along X / Y / Z (1)" Click="MoveModeButton_Click" />
                    <RadioButton x:Name="rotateModeButton" Content="Rotate (2)" GroupName="GizmoMode" Width="72" Height="26" Margin="2,0"
                                 ToolTip="Rotate selected entity around X / Y / Z (2)" Click="RotateModeButton_Click" />
                </StackPanel>
                <CheckBox x:Name="localAxesCheckBox" Content="Local axes" Margin="4,6,2,2" IsChecked="True"
                          ToolTip="When moving: drag along the entity's rotated axes. Off = world X/Y/Z." />
                <CheckBox x:Name="showGridCheckBox" Content="Show grid" Margin="4,2,2,2" IsChecked="True"
                          ToolTip="Toggle the horizontal reference grid" Checked="ShowGridCheckBox_Changed" Unchecked="ShowGridCheckBox_Changed" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
