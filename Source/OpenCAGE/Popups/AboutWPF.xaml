<UserControl x:Class="CommandsEditor.Popups.AboutWPF"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CommandsEditor.Popups"
             mc:Ignorable="d" 
             d:DesignHeight="489" d:DesignWidth="1100">
    <UserControl.Resources>
        <FontFamily x:Key="Isolation">/Fonts/#Isolation</FontFamily>
        <FontFamily x:Key="Jixellation">/Fonts/#Jixellation</FontFamily>
        <Style x:Key="TextButton" TargetType="{x:Type Button}" BasedOn="{x:Null}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="{StaticResource Isolation}"/>
            <Setter Property="FontSize" Value="55"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid x:Name="Grid">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" RecognizesAccessKey="True"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="LightGray"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Foreground" Value="DarkGray"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ImageButton" TargetType="{x:Type Button}" BasedOn="{StaticResource TextButton}">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="10 0 0 0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.75"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Width="1100" Height="489">
        <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center" Margin="70,0,0,0">
            <Image Source="/Images/about_logo.png" Height="194" Width="388"/>
        </WrapPanel>

        <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,48,0">
            <StackPanel>
                <Label Foreground="White" FontFamily="{StaticResource Isolation}" FontSize="40" HorizontalContentAlignment="Right" Content="Created by Matt Filer"/>
                <Label x:Name="VersionText" Foreground="White" FontFamily="{StaticResource Jixellation}" FontSize="20" HorizontalContentAlignment="Right" Content="[BRANCH] VERSION 0.0.0.0"/>
                
                <WrapPanel HorizontalAlignment="Right" Margin="0 10 0 0">
                    <Button Style="{StaticResource ImageButton}" ToolTip="Visit OpenCAGE on GitHub" Click="GithubButtonClick" Margin="4 0">
                        <Image Source="/Images/github.png" RenderOptions.BitmapScalingMode="HighQuality" Opacity="1"></Image>
                    </Button>
                    <Button Style="{StaticResource ImageButton}" ToolTip="Visit the OpenCAGE Docs" Click="DocsButtonClick" Margin="4 0">
                        <Image Source="/Images/docs.png" RenderOptions.BitmapScalingMode="HighQuality" Opacity="1"></Image>
                    </Button>
                    <Button Style="{StaticResource ImageButton}" ToolTip="Join the OpenCAGE community on Discord" Click="DiscordButtonClick" Margin="4 0">
                        <Image Source="/Images/discord.png" RenderOptions.BitmapScalingMode="HighQuality" Opacity="1"></Image>
                    </Button>
                    <Button Style="{StaticResource ImageButton}" ToolTip="Follow MattFiler on X (Twitter) for updates" Click="TwitterButtonClick" Margin="4 0">
                        <Image Source="/Images/x.png" RenderOptions.BitmapScalingMode="HighQuality" Opacity="1"></Image>
                    </Button>
                    <Button Style="{StaticResource ImageButton}" ToolTip="Follow MattFiler on Bluesky for updates" Click="BlueskyButtonClick" Margin="4 0">
                        <Image Source="/Images/bluesky.png" RenderOptions.BitmapScalingMode="HighQuality" Opacity="1"></Image>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </WrapPanel>

        <Grid.Background>
            <ImageBrush Stretch="None" ImageSource="/Images/about_bg.png" AlignmentY="Center" AlignmentX="Center"/>
        </Grid.Background>
    </Grid>
</UserControl>
